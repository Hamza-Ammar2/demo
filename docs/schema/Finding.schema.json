{
  "$defs": {
    "AnalysisMode": {
      "description": "Mandatory, no implicit default anywhere it is consumed.\n\nretrospective: may use later-confirmed information (e.g. next menstrual onset)\n               to reconstruct past phase. Valid for describing past patterns.\ncausal:        may use ONLY information available at/before the analysis time.\n               Mandatory for any forward-looking / predictive claim.",
      "enum": [
        "retrospective",
        "causal"
      ],
      "title": "AnalysisMode",
      "type": "string"
    },
    "Certainty": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ],
      "title": "Certainty",
      "type": "string"
    },
    "EstablishmentClass": {
      "enum": [
        "established",
        "possible",
        "not_established",
        "missing"
      ],
      "title": "EstablishmentClass",
      "type": "string"
    },
    "FindingType": {
      "enum": [
        "temporal_association",
        "change_after_event",
        "confounder",
        "missing_information",
        "data_quality"
      ],
      "title": "FindingType",
      "type": "string"
    },
    "ProvenanceStatus": {
      "enum": [
        "complete",
        "partial",
        "unverified"
      ],
      "title": "ProvenanceStatus",
      "type": "string"
    }
  },
  "properties": {
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "finding_id": {
      "title": "Finding Id",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "statement": {
      "description": "Plain-language, association-only phrasing.",
      "title": "Statement",
      "type": "string"
    },
    "finding_type": {
      "$ref": "#/$defs/FindingType"
    },
    "supporting_event_ids": {
      "items": {
        "type": "string"
      },
      "title": "Supporting Event Ids",
      "type": "array"
    },
    "contradicting_event_ids": {
      "items": {
        "type": "string"
      },
      "title": "Contradicting Event Ids",
      "type": "array"
    },
    "confounder_event_ids": {
      "items": {
        "type": "string"
      },
      "title": "Confounder Event Ids",
      "type": "array"
    },
    "source_ids": {
      "items": {
        "type": "string"
      },
      "title": "Source Ids",
      "type": "array"
    },
    "strength": {
      "$ref": "#/$defs/Certainty",
      "default": "unknown"
    },
    "method": {
      "description": "Name of the deterministic method used.",
      "title": "Method",
      "type": "string"
    },
    "analysis_mode": {
      "$ref": "#/$defs/AnalysisMode",
      "description": "Mandatory."
    },
    "establishment": {
      "$ref": "#/$defs/EstablishmentClass",
      "default": "possible"
    },
    "limitation": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Limitation"
    },
    "metrics": {
      "additionalProperties": true,
      "description": "Transparent numbers behind the finding (episode counts, rates, etc.).",
      "title": "Metrics",
      "type": "object"
    },
    "provenance_status": {
      "$ref": "#/$defs/ProvenanceStatus",
      "default": "unverified"
    }
  },
  "required": [
    "finding_id",
    "title",
    "statement",
    "finding_type",
    "method",
    "analysis_mode"
  ],
  "title": "Finding",
  "type": "object"
}