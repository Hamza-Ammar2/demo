{
  "$defs": {
    "Certainty": {
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ],
      "title": "Certainty",
      "type": "string"
    },
    "DatePrecision": {
      "description": "Precision of a timestamp, so the timeline compiler can reason about vagueness.",
      "enum": [
        "exact",
        "day",
        "approximate",
        "range",
        "unknown"
      ],
      "title": "DatePrecision",
      "type": "string"
    },
    "EventType": {
      "enum": [
        "symptom",
        "menstrual_onset",
        "estimated_cycle_phase",
        "ovulation_proxy",
        "medication_started",
        "medication_stopped",
        "dose_changed",
        "contraception_changed",
        "sleep_measurement",
        "stress_entry",
        "wearable_measurement",
        "glucose_measurement",
        "hormone_measurement",
        "laboratory_result",
        "clinical_encounter",
        "free_text_note"
      ],
      "title": "EventType",
      "type": "string"
    },
    "EvidenceClass": {
      "description": "How a value came to be known. Ordered from strongest to weakest evidence.",
      "enum": [
        "measured",
        "documented",
        "patient_reported",
        "inferred"
      ],
      "title": "EvidenceClass",
      "type": "string"
    }
  },
  "properties": {
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "subject_id": {
      "title": "Subject Id",
      "type": "string"
    },
    "event_type": {
      "$ref": "#/$defs/EventType"
    },
    "label": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Human label, e.g. 'severe migraine'.",
      "title": "Label"
    },
    "start": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Start"
    },
    "end": {
      "anyOf": [
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "For ranges/durations.",
      "title": "End"
    },
    "date_precision": {
      "$ref": "#/$defs/DatePrecision",
      "default": "unknown"
    },
    "value": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Value"
    },
    "unit": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Unit"
    },
    "severity": {
      "anyOf": [
        {
          "maximum": 10,
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "0-10 severity where meaningful.",
      "title": "Severity"
    },
    "certainty": {
      "$ref": "#/$defs/Certainty",
      "default": "unknown"
    },
    "evidence_class": {
      "$ref": "#/$defs/EvidenceClass",
      "default": "patient_reported"
    },
    "source_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Id"
    },
    "observed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "When this was recorded/known (drives causal leakage checks).",
      "title": "Observed At"
    },
    "cycle_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cycle Id"
    },
    "medication_context": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Medication Context"
    }
  },
  "required": [
    "event_id",
    "subject_id",
    "event_type"
  ],
  "title": "HealthEvent",
  "type": "object"
}