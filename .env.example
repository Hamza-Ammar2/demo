# Copy to .env and fill in. The Sarah demo and full deterministic pipeline
# run WITHOUT any of these (offline-first). These only enable live LLM extraction.

# OpenAI-compatible provider (optional; demo works without it)
OPENAI_API_KEY=
CYCLEBENCH_LLM_MODEL=gpt-4o-mini

# Prefer FedPer GRU phase model when torch + checkpoint exist (default 1). Set 0 for sklearn only.
CYCLEBENCH_USE_PFL=1

# PhysioNet credentials (only needed to (re)download mcPHASES; never commit real values)
PHYSIONET_USER=
PHYSIONET_PASSWORD=

# Kaggle API token (only needed for scripts/download_kaggle.py: PCOS + medical Q&A).
# Get it at kaggle.com -> Settings -> API -> Create New Token (or drop kaggle.json in ~/.kaggle/).
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional Hugging Face dataset for consented federated peer logs (Hamza fed upgrade).
# Without these, pFL peers fall back to local results/hf_export/data or mcPHASES.
HF_TOKEN=
HF_DATASET_REPO=

